<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Nuevo producto - FerreControl</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
<main class="container">
    <header class="page-header">
        <div>
            <h1>Nuevo producto</h1>
            <p>Registrar producto en el inventario</p>
        </div>

        <a href="/productos" class="btn btn-secondary">Volver</a>
    </header>

    <section class="card">
        <form method="POST" action="/productos" class="form">
            <label>
                Nombre
                <input type="text" name="nombre" required maxlength="120">
            </label>

            <label>
                Descripción
                <textarea name="descripcion" rows="4"></textarea>
            </label>

            <label>
                Cantidad en stock
                <input type="number" name="cantidad" required min="0">
            </label>

            <label>
                Precio unitario
                <input type="number" name="precio" required min="0" step="0.01">
            </label>

            <button type="submit" class="btn btn-primary">Guardar producto</button>
        </form>
    </section>
</main>
</body>
</html>