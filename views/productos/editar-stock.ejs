<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Actualizar stock - FerreControl</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
<main class="container">
    <header class="page-header">
        <div>
            <h1>Actualizar stock</h1>
            <p><%= producto.nombre %></p>
        </div>

        <a href="/productos/<%= producto.id %>" class="btn btn-secondary">Volver</a>
    </header>

    <% if (typeof mensaje !== 'undefined' && mensaje) { %>
        <div class="alert alert-success"><%= mensaje %></div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <section class="card">
        <form method="POST" action="/productos/<%= producto.id %>/stock?_method=PUT" class="form">
            <p><strong>Stock actual:</strong> <%= producto.cantidad %></p>

            <label>
                Tipo de movimiento
                <select name="tipo_movimiento" required>
                    <option value="">Seleccione una opción</option>
                    <option value="entrada">Entrada</option>
                    <option value="salida">Salida</option>
                    <option value="ajuste">Ajuste</option>
                </select>
            </label>

            <label>
                Cantidad
                <input
                        type="number"
                        name="cantidad"
                        required
                        min="1"
                        placeholder="Ejemplo: 5"
                >
            </label>

            <p class="form-help">
                <strong>Entrada:</strong> suma la cantidad al stock actual.<br>
                <strong>Salida:</strong> resta la cantidad del stock actual.<br>
                <strong>Ajuste:</strong> establece la cantidad ingresada como el stock final corregido.
            </p>

            <label>
                Motivo
                <input
                        type="text"
                        name="motivo"
                        maxlength="200"
                        placeholder="Ejemplo: reposición, venta, pérdida, daño o corrección"
                >
            </label>

            <button type="submit" class="btn btn-primary">Guardar movimiento</button>
        </form>
    </section>
</main>
</body>
</html>
