<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Detalle producto - FerreControl</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <main class="container">
    <header class="page-header">
      <div>
        <h1><%= producto.nombre %></h1>
        <p>Detalle del producto</p>
      </div>

      <a href="/productos" class="btn btn-secondary">Volver</a>
    </header>

    <% if (typeof mensaje !== 'undefined' && mensaje) { %>
      <div class="alert alert-success"><%= mensaje %></div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <section class="card detail-card">
      <p><strong>ID:</strong> <%= producto.id %></p>
      <p><strong>Descripción:</strong> <%= producto.descripcion || 'Sin descripción' %></p>
      <p><strong>Cantidad:</strong> <%= producto.cantidad %></p>
      <p><strong>Stock mínimo:</strong> <%= producto.stock_minimo %></p>
      <p><strong>Precio unitario:</strong> $<%= Number(producto.precio).toFixed(2) %></p>
      <p><strong>Valor total:</strong> $<%= (Number(producto.cantidad) * Number(producto.precio)).toFixed(2) %></p>
      <p><strong>Categoría:</strong> <%= producto.categoria || 'Sin categoría' %></p>
      <p><strong>Proveedor:</strong> <%= producto.proveedor || 'Sin proveedor' %></p>

      <div class="actions">
        <a href="/productos/<%= producto.id %>/stock" class="btn btn-primary">Actualizar stock</a>

        <form
          method="POST"
          action="/productos/<%= producto.id %>?_method=DELETE"
          onsubmit="return confirm('¿Eliminar este producto?');"
        >
          <button type="submit" class="btn btn-danger">Eliminar producto</button>
        </form>
      </div>
    </section>

    <section class="card movements-card">
      <h2>Historial de movimientos</h2>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Tipo de movimiento</th>
              <th>Cantidad</th>
              <th>Motivo</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody>
            <% if (typeof movimientos === 'undefined' || !movimientos || movimientos.length === 0) { %>
              <tr>
                <td colspan="4" class="empty">No hay movimientos registrados para este producto.</td>
              </tr>
            <% } else { %>
              <% movimientos.forEach(movimiento => { %>
                <tr>
                  <td>
                    <span class="movement-type movement-<%= movimiento.tipo_movimiento %>">
                      <%= movimiento.tipo_movimiento %>
                    </span>
                  </td>
                  <td><%= movimiento.cantidad %></td>
                  <td><%= movimiento.motivo || 'Sin motivo' %></td>
                  <td><%= movimiento.fecha_formateada %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
