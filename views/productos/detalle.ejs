<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detalle producto - FerreControl</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
  <header class="app-header">
    <div class="header-inner">
      <a href="/productos" class="brand" aria-label="Ir al inventario">
        <span class="brand-icon" aria-hidden="true">🔧</span>
        <span class="brand-copy">
          <strong>FerreControl</strong>
          <small>Sistema de inventario distribuido</small>
        </span>
      </a>

      <a href="/productos" class="btn btn-secondary">Volver</a>
    </div>
  </header>

  <main class="container">
    <% if (typeof mensaje !== 'undefined' && mensaje) { %>
      <div class="alert alert-success"><%= mensaje %></div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <section class="section">
      <div class="section-header">
        <span class="section-stripe stripe-accent" aria-hidden="true"></span>
        <div>
          <h1 class="section-title"><%= producto.nombre %></h1>
          <p class="section-desc">Detalle general del producto #<%= producto.id %></p>
        </div>
      </div>

      <div class="detail-content">
        <div class="detail-grid">
          <article class="detail-item detail-wide">
            <span class="detail-label">Descripción</span>
            <strong><%= producto.descripcion || 'Sin descripción' %></strong>
          </article>
          <article class="detail-item">
            <span class="detail-label">Cantidad</span>
            <strong class="detail-value"><%= producto.cantidad %></strong>
          </article>
          <article class="detail-item">
            <span class="detail-label">Stock mínimo</span>
            <strong class="detail-value"><%= producto.stock_minimo %></strong>
          </article>
          <article class="detail-item">
            <span class="detail-label">Precio unitario</span>
            <strong class="detail-value money">$<%= Number(producto.precio).toFixed(2) %></strong>
          </article>
          <article class="detail-item">
            <span class="detail-label">Valor total</span>
            <strong class="detail-value money">$<%= (Number(producto.cantidad) * Number(producto.precio)).toFixed(2) %></strong>
          </article>
          <article class="detail-item">
            <span class="detail-label">Categoría</span>
            <strong><span class="tag"><%= producto.categoria || 'Sin categoría' %></span></strong>
          </article>
          <article class="detail-item">
            <span class="detail-label">Proveedor</span>
            <strong><%= producto.proveedor || 'Sin proveedor' %></strong>
          </article>
        </div>

        <div class="detail-actions">
          <a href="/productos/<%= producto.id %>/stock" class="btn btn-primary">Actualizar stock</a>
          <form
            method="POST"
            action="/productos/<%= producto.id %>?_method=DELETE"
            onsubmit="return confirm('¿Eliminar este producto?');"
          >
            <button type="submit" class="btn btn-danger">Eliminar producto</button>
          </form>
        </div>
      </div>
    </section>

    <section class="section movements-section">
      <div class="section-header">
        <span class="section-stripe stripe-success" aria-hidden="true"></span>
        <div>
          <h2 class="section-title">Historial de movimientos</h2>
          <p class="section-desc">Últimos cambios registrados en el stock</p>
        </div>
      </div>

      <div class="table-wrapper">
        <table class="dashboard-table">
          <thead>
            <tr>
              <th>Tipo de movimiento</th>
              <th>Cantidad</th>
              <th>Motivo</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody>
            <% if (typeof movimientos === 'undefined' || !movimientos || movimientos.length === 0) { %>
              <tr>
                <td colspan="4" class="empty">No hay movimientos registrados para este producto.</td>
              </tr>
            <% } else { %>
              <% movimientos.forEach(movimiento => { %>
                <tr>
                  <td>
                    <span class="movement-type movement-<%= movimiento.tipo_movimiento %>">
                      <%= movimiento.tipo_movimiento %>
                    </span>
                  </td>
                  <td class="num"><%= movimiento.cantidad %></td>
                  <td><%= movimiento.motivo || 'Sin motivo' %></td>
                  <td class="muted-text"><%= movimiento.fecha_formateada || 'Fecha no disponible' %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
