MYSQL_PASSWORD=ferrecontrol_pass
MYSQL_ROOT_PASSWORD=ferrecontrol_root_pass

# Configuración de conexión para el módulo de reportes (y para tu compañero)
DB_HOST=ferrecontrol_db
